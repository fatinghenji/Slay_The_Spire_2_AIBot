{
  "version": 3,
  "description": "Canonical Slay the Spire 2 knowledge base schema for core/custom layered loading.",
  "jsonFiles": {
    "characters.json": { "type": "CharacterGuideEntry[]", "key": "id" },
    "builds.json": { "type": "BuildGuideEntry[]", "key": "id" },
    "cards.json": { "type": "CardGuideEntry[]", "key": "slug" },
    "relics.json": { "type": "RelicGuideEntry[]", "key": "slug" },
    "potions.json": {
      "type": "PotionEntry[]",
      "key": "slug",
      "notes": [
        "PotionEntry supports targetType, effectFormulaEn, and effectFormulaZh.",
        "Use targetType values that match in-game semantics such as Self, AnyPlayer, or AllEnemies."
      ]
    },
    "powers.json": {
      "type": "PowerEntry[]",
      "key": "slug",
      "notes": [
        "PowerEntry supports stackType, stackRuleEn, stackRuleZh, resolutionRuleEn, and resolutionRuleZh.",
        "Use stackType values that match in-game semantics such as Counter or Single."
      ]
    },
    "enemies.json": { "type": "EnemyEntry[]", "key": "slug" },
    "events.json": { "type": "EventEntry[]", "key": "slug" },
    "enchantments.json": { "type": "EnchantmentEntry[]", "key": "slug" },
    "game_mechanics.json": { "type": "MechanicRule[]", "key": "id" }
  },
  "guideFiles": [
    "guides/overview.md",
    "guides/general_strategy.md",
    "guides/ironclad.md",
    "guides/silent.md",
    "guides/defect.md",
    "guides/regent.md",
    "guides/necrobinder.md"
  ]
}
